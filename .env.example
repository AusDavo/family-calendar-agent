# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # comma-separated Telegram user IDs

# CalDAV
CALDAV_URL=                      # e.g. https://caldav.fastmail.com/dav/calendars/user/you@example.com/
CALDAV_USERNAME=
CALDAV_PASSWORD=                 # app-specific password
CALENDAR_NAMES=                  # optional: comma-separated calendar names to include (default: all)
WRITABLE_CALENDARS=              # optional: comma-separated calendars that allow create/delete (default: all)

# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                  # for memory server embeddings

# General
TIMEZONE=Australia/Brisbane

# Memory server
POSTGRES_USER=memory
POSTGRES_PASSWORD=
POSTGRES_DB=memory
DATABASE_URL=postgresql://memory:<password>@memory-db:5432/memory
MEMORY_SERVER_URL=http://memory-server:8000/mcp/
MCP_API_KEY=                     # shared secret for memory server auth
